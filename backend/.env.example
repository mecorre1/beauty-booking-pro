# Copy to backend/.env and adjust.
# Paths are relative to the current working directory when starting the API (use `cd backend`).

DATABASE_URL=sqlite:///./data/app.db

# First admin (created on startup only when the users table is empty). Defaults match local dev.
# BOOTSTRAP_ADMIN_EMAIL=admin@admin.com
# BOOTSTRAP_ADMIN_PASSWORD=admin
# To skip bootstrap and use POST /api/admin/auth/register instead, clear both, e.g.:
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
